@startuml
skinparam ArrowFontStyle plain
skinparam maxMessageSize 100

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant ":PharmaTrackerParser" as PTP
participant "parser:AddCommandParser" as AddParser
participant "<<class>>\nMedicationParserUtil" as MedParserUtil
participant "c:AddCommand" as AddCommand
participant "med:Medication" as Medication
participant "inv:Inventory" as Inventory

User -> PharmaTracker : "add /n Paracetamol /d 500mg..."
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> PTP : parse(fullCommand)
activate PTP

create AddParser
PTP -> AddParser : new AddCommandParser()
activate AddParser
AddParser --> PTP : parser
deactivate AddParser

PTP -> AddParser : parse(description)
activate AddParser

AddParser -> MedParserUtil : extractName(description)
activate MedParserUtil
MedParserUtil --> AddParser : name
deactivate MedParserUtil

AddParser -> MedParserUtil : extractDosage(description)
activate MedParserUtil
MedParserUtil --> AddParser : dosage
deactivate MedParserUtil

AddParser -> MedParserUtil : extractQuantity(description)
activate MedParserUtil
MedParserUtil --> AddParser : quantity
deactivate MedParserUtil

AddParser -> MedParserUtil : extractExpiryDate(description)
activate MedParserUtil
MedParserUtil --> AddParser : expiryDate
deactivate MedParserUtil

note right of AddParser
  Optional flags and warnings are
  extracted using ParserUtil and
  MedicationParserUtil.extractWarnings()
end note

create AddCommand
AddParser -> AddCommand : new AddCommand(name, dosage, quantity, ...)
activate AddCommand
AddCommand --> AddParser : c
deactivate AddCommand

AddParser --> PTP : c
deactivate AddParser

PTP --> PharmaTracker : c
deactivate PTP

PharmaTracker -> AddCommand : execute(inv, ui, customerList)
activate AddCommand

create Medication
AddCommand -> Medication : new Medication(name, dosage, quantity, expiryDate, tag)
activate Medication
Medication --> AddCommand : med
deactivate Medication

opt if optional attributes present
    AddCommand -> Medication : setDosageForm(dosageForm)
    activate Medication
    Medication --> AddCommand
    deactivate Medication

    note right of AddCommand
      Other optional setters (Manufacturer,
      Route, etc.) and addWarning()
      are called here.
    end note
end

AddCommand -> Inventory : addMedication(med)
activate Inventory
Inventory --> AddCommand
deactivate Inventory

AddCommand -> Ui : printAddedMessage(med, inv)
activate Ui
Ui --> AddCommand
deactivate Ui

AddCommand --> PharmaTracker
deactivate AddCommand
AddCommand -[hidden]-> AddParser
destroy AddCommand

deactivate PharmaTracker
@enduml