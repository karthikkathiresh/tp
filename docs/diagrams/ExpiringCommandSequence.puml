@startuml
skinparam ArrowFontStyle plain

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant "<<class>>\nPharmaTrackerParser" as Parser
participant "c:ExpiringCommand" as ExpiringCommand
participant "inv:Inventory" as Inventory
participant "med:Medication" as Medication

User -> PharmaTracker : "expiring /days 14"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> Parser : parse(fullCommand)
activate Parser

create ExpiringCommand
alt no /days argument provided
    Parser -> ExpiringCommand : new ExpiringCommand()
else valid /days argument provided
    Parser -> ExpiringCommand : new ExpiringCommand(days)
end
activate ExpiringCommand
ExpiringCommand --> Parser : c
deactivate ExpiringCommand

Parser --> PharmaTracker : c
deactivate Parser

PharmaTracker -> ExpiringCommand : execute(inv, ui, customerList)
activate ExpiringCommand

ExpiringCommand -> Inventory : getMedications()
activate Inventory
Inventory --> ExpiringCommand : medicationList
deactivate Inventory

loop for each medication
    ExpiringCommand -> Medication : getExpiryDate()
    activate Medication
    Medication --> ExpiringCommand : expiry
    deactivate Medication

    alt expiry is null or invalid
        note right of ExpiringCommand
          Medication is skipped if the
          expiry date is missing or
          cannot be parsed.
        end note
    else expired before today
        ExpiringCommand -> ExpiringCommand : expiredMeds.add(med)
    else within cutoff window
        ExpiringCommand -> ExpiringCommand : expiringMeds.add(med)
    end
end

ExpiringCommand -> Ui : showExpiringMedications(expiredMeds, expiringMeds, days)
activate Ui
Ui --> ExpiringCommand
deactivate Ui

ExpiringCommand --> PharmaTracker
deactivate ExpiringCommand
destroy ExpiringCommand

deactivate PharmaTracker
@enduml
