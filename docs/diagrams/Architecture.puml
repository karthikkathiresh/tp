@startuml
skinparam ArrowFontStyle plain
skinparam packageStyle rectangle

actor User

package "PharmaTracker (Main)" {
    [Ui]

    package "Parser System" {
        [PharmaTrackerParser]
        [SubParsers]
        [ParserUtils]
    }

    [Commands]
    [AppServices]
    [AuthService]
    [RestockAlertService]
    [Inventory]
    [CustomerList]
    [Storage]
}

package "Commons" {
    [LoggerSetup]
    [PharmaTrackerException]
}

database "Data Files" as Files {
    file "pharmatracker.txt"
    file "customers.txt"
    file "users.txt"
    file "dispense_log.txt"
}

User --> [Ui] : input
[Ui] --> [PharmaTrackerParser] : parse(fullCommand)

' Parser Delegation Logic
[PharmaTrackerParser] --> [SubParsers] : delegates to
[SubParsers] ..> [ParserUtils] : uses for validation
[SubParsers] --> [Commands] : instantiate

[Commands] --> [AppServices] : access services
[AppServices] ..> [AuthService]
[AppServices] ..> [RestockAlertService]

[Commands] --> [Inventory] : read / modify
[Commands] --> [CustomerList] : read / modify
[Commands] --> [AuthService] : authenticate
[Commands] --> [RestockAlertService] : evaluate

' Storage Logic
[Storage] --> [Inventory] : load / save
[Storage] --> [CustomerList] : load / save

' Specific File Routing
[Storage] --> [pharmatracker.txt] : read / write
[Storage] --> [customers.txt] : read / write
[Storage] --> [users.txt] : read / write
[Storage] --> [dispense_log.txt] : read / write

[LoggerSetup] ..> [PharmaTrackerParser] : init
[PharmaTrackerException] ..> [Commands] : thrown by
[PharmaTrackerException] ..> [SubParsers] : thrown by

@enduml