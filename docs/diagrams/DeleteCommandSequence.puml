@startuml
skinparam ArrowFontStyle plain
skinparam maxMessageSize 100

actor User
participant ":PharmaTracker" as PharmaTracker
participant ":Ui" as Ui
participant ":PharmaTrackerParser" as PTP
participant "parser:DeleteCommandParser" as DeleteParser
participant "d:DeleteCommand" as DeleteCommand
participant ":Inventory" as Inventory
participant ":Storage" as Storage

User -> PharmaTracker : "delete 5"
activate PharmaTracker

PharmaTracker -> Ui : readCommand()
activate Ui
Ui --> PharmaTracker : fullCommand
deactivate Ui

PharmaTracker -> PTP : parse(fullCommand)
activate PTP

create DeleteParser
PTP -> DeleteParser : new DeleteCommandParser()
activate DeleteParser
DeleteParser --> PTP : parser
deactivate DeleteParser

PTP -> DeleteParser : parse("5")
activate DeleteParser

note right of DeleteParser
  Parses string to integer
  and converts to 0-based index
end note

create DeleteCommand
DeleteParser -> DeleteCommand : new DeleteCommand(targetIndex)
activate DeleteCommand
DeleteCommand --> DeleteParser : d
deactivate DeleteCommand

DeleteParser --> PTP : d
deactivate DeleteParser

PTP --> PharmaTracker : d
deactivate PTP

PharmaTracker -> DeleteCommand : execute(inventory, ui, customerList)
activate DeleteCommand

' --- NEW LOGIC: Validation Check ---
alt isValidIndex (index >= 0 && index < size)
    DeleteCommand -> Inventory : getMedication(targetIndex)
    activate Inventory
    Inventory --> DeleteCommand : med
    deactivate Inventory

    DeleteCommand -> Inventory : removeMedication(med)
    activate Inventory
    Inventory --> DeleteCommand
    deactivate Inventory

    DeleteCommand -> Ui : printDeletedMessage(med, inventory)
    activate Ui
    Ui --> DeleteCommand
    deactivate Ui
else isInvalidIndex
    DeleteCommand -> Ui : showError("Invalid index!")
    activate Ui
    Ui --> DeleteCommand
    deactivate Ui
end
' -----------------------------------

DeleteCommand --> PharmaTracker
deactivate DeleteCommand
DeleteCommand -[hidden]-> DeleteParser
destroy DeleteCommand

' Saving to Storage
PharmaTracker -> Storage : save(inventory)
activate Storage
Storage --> PharmaTracker
deactivate Storage

deactivate PharmaTracker
@enduml